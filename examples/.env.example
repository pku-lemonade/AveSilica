# TokenZulip runtime environment.
# Copy this file to .env in the repo clone and edit the values there.

TOKENZULIP_WORKSPACE=/runtime/workspace
TOKENZULIP_ZULIPRC=/runtime/.zuliprc

# Optional. If omitted, the bot tries to discover these from Zulip.
TOKENZULIP_REALM_ID=unknown
TOKENZULIP_BOT_EMAIL=
TOKENZULIP_BOT_USER_ID=
TOKENZULIP_BOT_ALIASES=Silica,Sili

# Codex runtime settings.
TOKENZULIP_CODEX_MODEL=gpt-5.5
TOKENZULIP_CODEX_REASONING_EFFORT=medium
TOKENZULIP_CODEX_SANDBOX=danger-full-access
TOKENZULIP_CODEX_APPROVAL_POLICY=never

# Route container network clients through a host-local HTTP proxy on port 50834.
HTTP_PROXY=http://127.0.0.1:50834
HTTPS_PROXY=http://127.0.0.1:50834
ALL_PROXY=http://127.0.0.1:50834
NO_PROXY=localhost,127.0.0.1,::1
http_proxy=http://127.0.0.1:50834
https_proxy=http://127.0.0.1:50834
all_proxy=http://127.0.0.1:50834
no_proxy=localhost,127.0.0.1,::1

# Set to false for service-level dry-runs. The CLI --dry-run flag also disables posting.
TOKENZULIP_POSTING_ENABLED=true

# Typing indicators are shown only for private messages and direct mentions.
TOKENZULIP_TYPING_ENABLED=true
TOKENZULIP_TYPING_REFRESH_SECONDS=8

# Scheduled task support. Set timezone explicitly for Docker.
TOKENZULIP_SCHEDULES_ENABLED=true
TOKENZULIP_SCHEDULE_TICK_SECONDS=60
TOKENZULIP_SCHEDULE_TIMEZONE=Asia/Shanghai
TOKENZULIP_SCHEDULE_RUN_TIMEOUT_SECONDS=600

# Prompt/debug trace sidecars. Auto cleanup deletes only workspace/records/**/traces/.
TOKENZULIP_TRACE_RETENTION_DAYS=30
TOKENZULIP_TRACE_AUTO_CLEANUP=false
TOKENZULIP_TRACE_CLEANUP_INTERVAL_HOURS=24

# Maximum uploaded file size to download into workspace/records before a Codex turn.
TOKENZULIP_UPLOAD_MAX_BYTES=25000000

# Set to false to listen only in channels where the bot is explicitly subscribed.
TOKENZULIP_LISTEN_ALL_PUBLIC_STREAMS=true

# Provide whatever credentials your Codex SDK runtime requires.
# OPENAI_API_KEY=
