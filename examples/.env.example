# TokenZulip runtime environment.
# Copy to /etc/token-zulip/token-zulip.env for the systemd example.

TOKENZULIP_WORKSPACE=/app/workspace
TOKENZULIP_ZULIPRC=/run/secrets/zuliprc

# Optional. If omitted, the bot tries to discover these from Zulip.
TOKENZULIP_REALM_ID=unknown
TOKENZULIP_BOT_EMAIL=

# Codex runtime settings.
TOKENZULIP_CODEX_MODEL=gpt-5.4
TOKENZULIP_CODEX_SANDBOX=read-only
TOKENZULIP_CODEX_APPROVAL_POLICY=never

# Set to false for service-level dry-runs. The CLI --dry-run flag also disables posting.
TOKENZULIP_POST_REPLIES=true

# Provide whatever credentials your Codex SDK runtime requires.
# OPENAI_API_KEY=

