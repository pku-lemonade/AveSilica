{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "should_reply",
    "reply_kind",
    "message_to_post",
    "memory_ops",
    "confidence"
  ],
  "properties": {
    "should_reply": {
      "type": "boolean"
    },
    "reply_kind": {
      "type": "string",
      "enum": [
        "chat",
        "draft_plan",
        "question",
        "report",
        "silent"
      ]
    },
    "message_to_post": {
      "type": "string"
    },
    "memory_ops": {
      "description": "Memory write requests from scheduled job runs. Use an empty array when scoped memory should not change.",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "op",
          "scope",
          "content",
          "old_text"
        ],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "add",
              "remove",
              "replace"
            ]
          },
          "scope": {
            "type": "string",
            "enum": [
              "channel",
              "conversation",
              "global"
            ]
          },
          "content": {
            "type": "string"
          },
          "old_text": {
            "type": "string"
          }
        }
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
